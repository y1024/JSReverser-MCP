{
  "target": {
    "site": "example-site",
    "scriptUrl": "https://static.example.com/security/sign.js",
    "entryType": "class-method",
    "entryName": "Signer.sign",
    "signatureField": "sign",
    "targetUrlPatterns": [
      "https://api.example.com/*"
    ],
    "targetKeywords": [
      "sign",
      "nonce",
      "timestamp"
    ]
  },
  "request": {
    "url": "https://api.example.com/v1/demo",
    "method": "GET",
    "paramsTemplate": {
      "functionId": "demoAction",
      "client": "web",
      "t": "{{fixedNow}}",
      "body": "{\"demo\":true}"
    },
    "headersTemplate": {
      "user-agent": "UA_PLACEHOLDER",
      "referer": "https://www.example.com/"
    }
  },
  "runtime": {
    "seedMode": "keys-only",
    "seedKeys": {
      "cookies": [
        "cookie_key_a",
        "cookie_key_b"
      ],
      "localStorage": [
        "ls_key_a",
        "ls_key_b"
      ],
      "sessionStorage": [
        "ss_key_a"
      ]
    },
    "clock": {
      "mode": "fixed",
      "fixedNow": 1700000000000
    },
    "environmentHints": [
      "requires-canvas",
      "requires-webgl"
    ]
  },
  "verify": {
    "enabled": true,
    "expectStatus": 200,
    "expectBodyContains": [
      "\"ok\":true"
    ],
    "maxAttempts": 1
  },
  "security": {
    "forbidRawSecrets": true,
    "forbidRawCookies": true,
    "forbidRawTokens": true
  }
}
